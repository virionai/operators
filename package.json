{
  "name": "operators",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Offline-first Capsules.run Operators blank investigation workspace for Gemma 4.",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:blank": "node scripts/assert-blank-workspace.mjs",
    "test:gates": "node scripts/assert-decision-gates-schema.mjs",
    "test:hud": "node scripts/assert-top-hud-layout.mjs",
    "test:analysis": "node scripts/assert-real-analysis-queue.mjs",
    "test:surfaces": "node scripts/assert-operational-surfaces.mjs",
    "test:spatial": "node scripts/assert-spatial-workspace.mjs",
    "test:ux": "node scripts/assert-workspace-ux.mjs",
    "test:operator-protocol": "node scripts/assert-protocol-operator.mjs",
    "test:asset-browser": "node scripts/assert-asset-browser.mjs",
    "test:capsule-hydration": "node scripts/assert-capsule-hydration.mjs",
    "test:runtime-connection": "node scripts/assert-runtime-connection.mjs",
    "test:final-ui": "node scripts/assert-final-ui-additions.mjs",
    "test:operator-console": "node scripts/assert-operator-console.mjs",
    "test:left-rail": "node scripts/assert-left-rail-containment.mjs",
